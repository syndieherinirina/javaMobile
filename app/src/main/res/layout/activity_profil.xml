<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profil"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="20dp" />

        <ImageView
            android:id="@+id/imgAvatarProfil"
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/avatar_profile"
            android:contentDescription="Avatar du profil"
            android:layout_marginBottom="18dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:tag="card"
            android:padding="18dp"
            android:layout_marginBottom="22dp">

            <TextView
                android:id="@+id/tvEmailProfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email :"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvPremiereConnexion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date de premiere connexion :"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvDerniereConnexion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Derniere connexion :"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvDerniereVisiteProfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Derniere visite du profil :"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvNombreVisitesProfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre de visites du profil : 0"
                android:textSize="15sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modifier l'email"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editNouvelEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Nouvel email"
            android:inputType="textEmailAddress"
            android:padding="14dp"
            android:tag="input"
            android:background="@drawable/edit_text_background"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="14dp" />

        <Button
            android:id="@+id/btnChangerEmail"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Changer mon email"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:background="@drawable/button_primary"
            android:layout_marginBottom="14dp" />

        <Button
            android:id="@+id/btnRetourProfil"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Retour"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:background="@drawable/button_light" />

    </LinearLayout>
</ScrollView>
